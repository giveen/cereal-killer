# Set this to your OpenAI-compatible endpoint.
# Local host machine example: http://host.docker.internal:8000/v1
# Remote machine example (llama.cpp): http://192.168.1.50:8000/v1
LLM_BASE_URL=http://192.168.1.50:8000/v1
LLM_MODEL=qwen3.6
LLM_API_KEY=not-needed
REASONING_PARSER=qwen3
MAX_MODEL_LEN=262144
