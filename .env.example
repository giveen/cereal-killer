# Set this to your OpenAI-compatible endpoint.
# Local host machine example: http://host.docker.internal:8000/v1
# Remote machine example (llama.cpp): http://192.168.1.50:8000/v1
LLM_BASE_URL=http://192.168.1.50:8000/v1
LLM_MODEL=qwen3.6
LLM_API_KEY=not-needed
REASONING_PARSER=qwen3
# Safety default: do not preserve/replay model thinking buffers into future requests.
# Set to 1 only if you explicitly want backend-specific reasoning passthrough.
PRESERVE_THINKING=0
MAX_MODEL_LEN=262144
BACKEND_TRACE_ENABLED=1
BACKEND_TRACE_PATH=logs/llm_backend.log

# Optional: override shell history file watched by the Terminal Link.
# Examples:
#   HISTORY_PATH=~/.bash_history
#   HISTORY_PATH=~/.zsh_history
HISTORY_PATH=~/.bash_history

# Optional: skip local setup validation checks when developing on a different host.
# Set to 1/true/yes/on to bypass scripts/setup/check_env.py from make check/run.
GIBSON_SKIP_ENV_CHECK=0

# Timeout in seconds for RAG search pipeline. If tiered_search takes longer than this,
# partial results are returned to avoid blocking the UI. Default: 10.
RAG_TIMEOUT=10
